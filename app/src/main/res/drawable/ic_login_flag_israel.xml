<?xml version="1.0" encoding="utf-8"?>
<!-- Israel — circular badge: white field, two blue stripes (simplified). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#333333" />
        </shape>
    </item>
    <item
        android:bottom="8dp"
        android:left="3dp"
        android:right="3dp"
        android:top="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#0038B8" />
        </shape>
    </item>
    <item
        android:bottom="13dp"
        android:left="3dp"
        android:right="3dp"
        android:top="13dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
