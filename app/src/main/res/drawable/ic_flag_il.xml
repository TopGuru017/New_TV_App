<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#444444" />
        </shape>
    </item>
    <item
        android:bottom="10dp"
        android:left="4dp"
        android:right="4dp"
        android:top="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#0038B8" />
        </shape>
    </item>
    <item
        android:bottom="14dp"
        android:left="4dp"
        android:right="4dp"
        android:top="14dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
