<?xml version="1.0" encoding="utf-8"?>
<!-- United Kingdom — circular badge: simplified Union Jack. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#333333" />
        </shape>
    </item>
    <item
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp">
        <shape android:shape="oval">
            <solid android:color="#012169" />
        </shape>
    </item>
    <!-- St George cross (white then red) -->
    <item
        android:bottom="5dp"
        android:left="14dp"
        android:right="14dp"
        android:top="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item
        android:bottom="14dp"
        android:left="5dp"
        android:right="5dp"
        android:top="14dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item
        android:bottom="7dp"
        android:left="15dp"
        android:right="15dp"
        android:top="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#C8102E" />
        </shape>
    </item>
    <item
        android:bottom="15dp"
        android:left="7dp"
        android:right="7dp"
        android:top="15dp">
        <shape android:shape="rectangle">
            <solid android:color="#C8102E" />
        </shape>
    </item>
</layer-list>
