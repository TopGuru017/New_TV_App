<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_records_program_card"
    android:baselineAligned="false"
    android:clickable="true"
    android:focusable="true"
    android:orientation="horizontal"
    android:padding="10dp">

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="32">

        <ImageView
            android:id="@+id/records_prog_thumb"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:background="#444" />

        <ImageView
            android:id="@+id/records_prog_play_overlay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:alpha="0.92"
            android:contentDescription="@string/records_cd_play"
            android:src="@android:drawable/ic_media_play"
            android:visibility="gone"
            tools:visibility="visible" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="68"
        android:orientation="vertical">

        <TextView
            android:id="@+id/records_prog_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/sidebar_text_muted"
            android:textSize="13sp"
            tools:text="04:20 - 04:45" />

        <TextView
            android:id="@+id/records_prog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/sidebar_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Programme title" />

        <TextView
            android:id="@+id/records_prog_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:lineSpacingExtra="3dp"
            android:maxLines="4"
            android:textColor="@color/sidebar_text_muted"
            android:textSize="13sp"
            tools:text="Description…" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/records_prog_genre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="12sp"
                tools:text="News &amp; Current Affairs" />

            <TextView
                android:id="@+id/records_prog_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="12sp"
                tools:text="00:25:00" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
