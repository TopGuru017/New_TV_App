<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-screen thumbnail background -->
    <ImageView
        android:id="@+id/vod_hero_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <!-- Dark overlay so content stays readable over any image -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B0000000" />

    <LinearLayout
        android:id="@+id/vod_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <!-- Info panel: badge, title, genre, description of focused item -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="6"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <!-- Title column (~22%) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="22"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingEnd="20dp">

                <TextView
                    android:id="@+id/vod_hero_left_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center_horizontal"
                    android:maxLines="4"
                    android:textColor="@color/sidebar_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Title" />
            </LinearLayout>

            <!-- Info column (~78%) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="78"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingTop="16dp"
                android:paddingEnd="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/vod_hero_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E53935"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="Movie" />

                <TextView
                    android:id="@+id/vod_hero_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:textColor="@color/sidebar_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="Programme title" />

                <TextView
                    android:id="@+id/vod_hero_genre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/sidebar_text_muted"
                    android:textSize="14sp"
                    tools:text="Category" />

                <View
                    android:id="@+id/vod_hero_genre_underline"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="6dp"
                    android:background="#55AAAAAA" />

                <TextView
                    android:id="@+id/vod_hero_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:ellipsize="end"
                    android:lineSpacingExtra="4dp"
                    android:maxLines="5"
                    android:textColor="@color/sidebar_text_primary"
                    android:textSize="15sp"
                    tools:text="Plot…" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="#28FFFFFF" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/vod_categories_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:clipChildren="false"
            android:clipToPadding="false">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/vod_items_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingTop="4dp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/vod_items_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/vod_empty_items"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="14sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/vod_loading"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/vod_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="24dp"
        android:textColor="#EF5350"
        android:textSize="15sp"
        android:visibility="gone"
        tools:text="@string/vod_load_error" />
</FrameLayout>
