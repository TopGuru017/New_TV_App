<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/last_watch_record_card_width"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="12dp">

    <FrameLayout
        android:id="@+id/last_watch_record_card"
        android:layout_width="match_parent"
        android:layout_height="@dimen/last_watch_record_card_height"
        android:background="@drawable/bg_last_watch_record_card"
        android:clickable="true"
        android:clipChildren="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/last_watch_record_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:background="#333" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_last_watch_record_overlay" />

        <TextView
            android:id="@+id/last_watch_record_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|top"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_last_watch_tag"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            tools:text="SPORT" />

        <TextView
            android:id="@+id/last_watch_record_center_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="NBA" />

        <TextView
            android:id="@+id/last_watch_record_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|top"
            android:layout_marginStart="8dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            android:textColor="@color/sidebar_text_primary"
            android:textSize="12sp"
            tools:text="- 01:40" />

        <FrameLayout
            android:id="@+id/last_watch_remove_badge"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_last_watch_remove_circle"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="×"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </FrameLayout>

    </FrameLayout>

    <TextView
        android:id="@+id/last_watch_record_bottom_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/sidebar_text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="NBA Daily" />

    <TextView
        android:id="@+id/last_watch_record_bottom_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/sidebar_text_muted"
        android:textSize="12sp"
        tools:text="23/03 - Monday" />
</LinearLayout>

