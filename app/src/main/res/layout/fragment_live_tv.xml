<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/content_background">

    <LinearLayout
        android:id="@+id/live_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <!-- Upper: hero — left channel mark, right programme title + category + plot -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4.5"
            android:clipChildren="false">

            <ImageView
                android:id="@+id/live_hero_watermark"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.1"
                android:contentDescription="@null"
                android:scaleType="centerInside" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Channel symbol + name (~22%) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="22"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="4dp"
                    android:paddingEnd="20dp">

                    <ImageView
                        android:id="@+id/live_hero_channel_logo"
                        android:layout_width="@dimen/live_hero_channel_logo_large"
                        android:layout_height="@dimen/live_hero_channel_logo_large"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/live_hero_channel_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:ellipsize="end"
                        android:gravity="center_horizontal"
                        android:maxLines="2"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="Channel 12" />
                </LinearLayout>

                <!-- Programme copy + optional backdrop -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="78">

                    <ImageView
                        android:id="@+id/live_hero_backdrop"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_live_hero_right_scrim" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingTop="16dp"
                        android:paddingEnd="24dp"
                        android:paddingBottom="16dp">

                        <TextView
                            android:id="@+id/live_now_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/live_now_badge"
                            android:textColor="#E53935"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/live_programme_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:ellipsize="end"
                            android:maxLines="3"
                            android:textColor="@color/sidebar_text_primary"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="Meet the new press" />

                        <TextView
                            android:id="@+id/live_genre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/sidebar_text_muted"
                            android:textSize="14sp"
                            tools:text="News &amp; Current Affairs" />

                        <View
                            android:id="@+id/live_genre_underline"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="6dp"
                            android:background="#55AAAAAA" />

                        <TextView
                            android:id="@+id/live_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:ellipsize="end"
                            android:lineSpacingExtra="4dp"
                            android:maxLines="5"
                            android:textColor="@color/sidebar_text_primary"
                            android:textSize="15sp"
                            tools:text="Short plot summary…" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </FrameLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="#28FFFFFF" />

        <!-- Categories strip -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/live_categories_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

        <!-- Channel grid -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="5.5">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/live_channels_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:descendantFocusability="afterDescendants"
                android:overScrollMode="never"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/live_channels_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/live_empty_channels"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="14sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/live_loading"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/live_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="24dp"
        android:textColor="#EF5350"
        android:textSize="15sp"
        android:visibility="gone"
        tools:text="@string/live_load_error" />
</FrameLayout>
