<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/content_background"
    android:orientation="vertical"
    android:paddingStart="@dimen/settings_content_padding"
    android:paddingTop="20dp"
    android:paddingEnd="@dimen/settings_content_padding"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/settings_screen_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:focusable="false"
        android:text="@string/settings_title"
        android:textColor="@color/sidebar_text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- Left nav -->
        <ScrollView
            android:layout_width="@dimen/settings_nav_column_width"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="none">

            <com.example.new_tv_app.ui.FocusColumnLayout
                android:id="@+id/settings_nav_column"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/settings_nav_background"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <include
                    android:id="@+id/nav_general"
                    layout="@layout/item_settings_nav" />

                <include
                    android:id="@+id/nav_display"
                    layout="@layout/item_settings_nav" />

                <include
                    android:id="@+id/nav_live"
                    layout="@layout/item_settings_nav" />

                <include
                    android:id="@+id/nav_manage_devices"
                    layout="@layout/item_settings_nav" />

                <include
                    android:id="@+id/nav_speed_test"
                    layout="@layout/item_settings_nav" />

                <include
                    android:id="@+id/nav_live_support"
                    layout="@layout/item_settings_nav" />

                <include
                    android:id="@+id/nav_log_out"
                    android:layout_marginTop="24dp"
                    layout="@layout/item_settings_nav" />
            </com.example.new_tv_app.ui.FocusColumnLayout>
        </ScrollView>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#28FFFFFF" />

        <com.example.new_tv_app.ui.FocusDetailColumnLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/settings_panel_background">

            <ScrollView
                android:id="@+id/settings_panel_general"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:focusable="false"
                android:padding="@dimen/settings_content_padding"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_section_language"
                        android:textColor="@color/settings_section_title"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/settings_lang_hebrew"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_settings_option_selected"
                            android:focusable="true"
                            android:gravity="center"
                            android:minHeight="48dp"
                            android:padding="12dp"
                            android:text="@string/settings_language_hebrew"
                            android:textColor="@color/sidebar_text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/settings_lang_english"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_settings_option_default"
                            android:focusable="true"
                            android:gravity="center"
                            android:minHeight="48dp"
                            android:padding="12dp"
                            android:text="@string/settings_language_english"
                            android:textColor="@color/sidebar_text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="24dp"
                        android:background="#28FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_section_records_order"
                        android:textColor="@color/settings_section_title"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/settings_order_new_old"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_settings_option_default"
                            android:focusable="true"
                            android:gravity="center"
                            android:minHeight="48dp"
                            android:padding="12dp"
                            android:text="@string/settings_records_new_to_old"
                            android:textColor="@color/sidebar_text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/settings_order_old_new"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_settings_option_selected"
                            android:focusable="true"
                            android:gravity="center"
                            android:minHeight="48dp"
                            android:padding="12dp"
                            android:text="@string/settings_records_old_to_new"
                            android:textColor="@color/sidebar_text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="24dp"
                        android:background="#28FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_section_update_notifications"
                        android:textColor="@color/settings_section_title"
                        android:textSize="14sp" />

                    <Switch
                        android:id="@+id/settings_update_notifications_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:focusable="true"
                        android:minHeight="48dp"
                        tools:ignore="UseSwitchCompatOrMaterialXml" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="24dp"
                        android:background="#28FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_section_storage"
                        android:textColor="@color/settings_section_title"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/settings_cache_size"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="14sp"
                        tools:text="Cache size: …" />

                    <TextView
                        android:id="@+id/settings_storage_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/sidebar_text_muted"
                        android:textSize="13sp"
                        tools:text="Total space: …" />

                    <TextView
                        android:id="@+id/settings_clear_cache"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_settings_option_selected"
                        android:focusable="true"
                        android:gravity="center"
                        android:minHeight="44dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="@string/settings_clear_cache"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/settings_panel_display"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:padding="@dimen/settings_content_padding"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/settings_panel_display_body"
                    android:textColor="@color/sidebar_text_primary"
                    android:textSize="15sp" />
            </ScrollView>

            <ScrollView
                android:id="@+id/settings_panel_live"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:padding="@dimen/settings_content_padding"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/settings_panel_live_body"
                    android:textColor="@color/sidebar_text_primary"
                    android:textSize="15sp" />
            </ScrollView>

            <ScrollView
                android:id="@+id/settings_panel_devices"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:padding="@dimen/settings_content_padding"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/settings_panel_devices_body"
                    android:textColor="@color/sidebar_text_primary"
                    android:textSize="15sp" />
            </ScrollView>

            <ScrollView
                android:id="@+id/settings_panel_speed"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:padding="@dimen/settings_content_padding"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/settings_speed_run_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_settings_option_selected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minHeight="44dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="@string/settings_speed_run"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/settings_speed_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/settings_speed_status_idle"
                        android:textColor="@color/sidebar_text_muted"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"
                        android:background="#28FFFFFF" />

                    <TextView
                        android:id="@+id/settings_speed_download"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_speed_download_fmt"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/settings_speed_upload"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/settings_speed_upload_fmt"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/settings_speed_ping"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/settings_speed_ping_fmt"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/settings_speed_last_run"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/settings_speed_last_run_fmt"
                        android:textColor="@color/sidebar_text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/settings_panel_support"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:padding="@dimen/settings_content_padding"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_support_title"
                        android:textColor="@color/settings_section_title"
                        android:textSize="36sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:text="@string/settings_support_subtitle"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="19sp" />

                    <FrameLayout
                        android:id="@+id/settings_support_qr_container"
                        android:layout_width="286dp"
                        android:layout_height="286dp"
                        android:layout_marginTop="28dp"
                        android:background="@drawable/bg_settings_support_qr_frame_selector"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/settings_support_qr_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_settings_support_qr_inner"
                            android:contentDescription="@string/settings_support_qr_cd"
                            android:padding="16dp"
                            android:scaleType="fitCenter" />
                    </FrameLayout>
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/settings_panel_logout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:padding="@dimen/settings_content_padding"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"
                        android:text="@string/settings_panel_logout_body"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/settings_logout_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_settings_option_selected"
                        android:focusable="true"
                        android:gravity="center"
                        android:minHeight="48dp"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:text="@string/settings_nav_log_out"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </ScrollView>
        </com.example.new_tv_app.ui.FocusDetailColumnLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/settings_build_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:focusable="false"
        android:textColor="@color/sidebar_text_muted"
        android:textSize="11sp"
        tools:text="Build: …" />
</LinearLayout>
