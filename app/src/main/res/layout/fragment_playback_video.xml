<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/vlc_video_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:fitsSystemWindows="true" />

    <!-- Bottom trick-play + timeline (VOD / seekable streams) -->
    <LinearLayout
        android:id="@+id/playback_controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC05070A"
        android:orientation="vertical"
        android:paddingStart="@dimen/playback_overlay_bottom_padding"
        android:paddingTop="12dp"
        android:paddingEnd="@dimen/playback_overlay_bottom_padding"
        android:paddingBottom="@dimen/playback_overlay_bottom_padding"
        android:visibility="gone"
        tools:visibility="visible">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playback_trick_rv"
            android:layout_width="match_parent"
            android:layout_height="@dimen/playback_trick_card_height"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/playback_time_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="52dp"
                android:textColor="@color/sidebar_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="0:46" />

            <ProgressBar
                android:id="@+id/playback_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:max="1000"
                android:progress="0"
                android:progressTint="@color/sidebar_accent_cyan"
                android:progressBackgroundTint="#33FFFFFF" />

            <TextView
                android:id="@+id/playback_time_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:minWidth="52dp"
                android:textColor="@color/sidebar_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="3:13:00" />
        </LinearLayout>
    </LinearLayout>

    <!-- Records catch-up only: vertical list for the selected day (DPAD up/down on video). -->
    <FrameLayout
        android:id="@+id/playback_records_column_container"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#CC05070A"
        android:focusable="false"
        android:visibility="gone"
        tools:visibility="visible">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playback_records_column_rv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="10dp"
            android:paddingTop="16dp"
            android:paddingEnd="10dp"
            android:paddingBottom="16dp" />
    </FrameLayout>
</FrameLayout>
