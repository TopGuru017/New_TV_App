<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/vlc_video_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:fitsSystemWindows="true"
        android:keepScreenOn="true"
        app:show_buffering="never"
        app:use_controller="false" />

    <!-- Bottom timeline (VOD / seekable streams): shown while seeking with DPAD left/right -->
    <LinearLayout
        android:id="@+id/playback_controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingStart="@dimen/playback_overlay_bottom_padding"
        android:paddingTop="12dp"
        android:paddingEnd="@dimen/playback_overlay_bottom_padding"
        android:paddingBottom="@dimen/playback_overlay_bottom_padding"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:id="@+id/playback_timeline_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/playback_time_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="52dp"
                android:textColor="@color/sidebar_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="0:46" />

            <ProgressBar
                android:id="@+id/playback_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:max="1000"
                android:progress="0"
                android:progressTint="@color/sidebar_accent_cyan"
                android:progressBackgroundTint="#33FFFFFF" />

            <TextView
                android:id="@+id/playback_time_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:minWidth="52dp"
                android:textColor="@color/sidebar_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="3:13:00" />
        </LinearLayout>
    </LinearLayout>

    <!-- Records catch-up: same bottom-card style as VOD info; ▲/▼ beside thumbnail browse the day list. -->
    <FrameLayout
        android:id="@+id/playback_records_info_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="false"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_playback_records_info_card"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="14dp"
                android:paddingEnd="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/playback_records_scroll_up"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false"
                        android:gravity="center"
                        android:importantForAccessibility="no"
                        android:minHeight="40dp"
                        android:minWidth="48dp"
                        android:text="▲"
                        android:textColor="@android:color/white"
                        android:textSize="20sp" />

                    <ImageView
                        android:id="@+id/playback_records_col_thumb"
                        android:layout_width="@dimen/playback_vod_thumb_width"
                        android:layout_height="@dimen/playback_vod_thumb_height"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/bg_playback_records_thumb_border_cyan"
                        android:contentDescription="@null"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:nextFocusLeft="@id/vlc_video_layout"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        tools:background="#444" />

                    <TextView
                        android:id="@+id/playback_records_scroll_down"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false"
                        android:gravity="center"
                        android:importantForAccessibility="no"
                        android:minHeight="40dp"
                        android:minWidth="48dp"
                        android:text="▼"
                        android:textColor="@android:color/white"
                        android:textSize="20sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/playback_records_info_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:maxLines="2"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="Programme title" />

                    <ProgressBar
                        android:id="@+id/playback_records_info_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="10dp"
                        android:max="1000"
                        android:progress="0"
                        android:progressBackgroundTint="#33FFFFFF"
                        android:progressTint="#E53935" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/playback_records_info_time_current"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:minWidth="72dp"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="00:00:01" />

                        <TextView
                            android:id="@+id/playback_records_info_time_total"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:focusable="false"
                            android:gravity="end"
                            android:minWidth="72dp"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="01:59:57" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/playback_records_info_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:maxLines="4"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        tools:text="Description…" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/playback_records_info_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:focusable="false"
                    android:maxLines="2"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    tools:text="21:30 - 23:30 · Thursday 26-03-2026 | Genre: Sports | 02:00:00" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- VOD playback: info + favorites (DPAD up/down on video to toggle). -->
    <FrameLayout
        android:id="@+id/playback_vod_info_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="false"
        android:visibility="gone"
        tools:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="20dp"
            android:minWidth="760dp"
            android:background="@drawable/bg_playback_records_info_card"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:id="@+id/playback_vod_info_thumb"
                    android:layout_width="@dimen/playback_vod_thumb_width"
                    android:layout_height="@dimen/playback_vod_thumb_height"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    tools:background="#444" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/playback_vod_info_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="How To Train Your Dragon 2025" />

                    <ProgressBar
                        android:id="@+id/playback_vod_info_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="10dp"
                        android:max="1000"
                        android:progress="0"
                        android:progressBackgroundTint="#33FFFFFF"
                        android:progressTint="#E53935" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/playback_vod_info_time_current"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="72dp"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="00:00:01" />

                        <TextView
                            android:id="@+id/playback_vod_info_time_total"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:minWidth="72dp"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="01:59:57" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/playback_vod_info_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="4"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        tools:text="Description…" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/playback_vod_info_meta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    tools:text="Genre: Children | 2025 | Time: 02:00:08" />

                <TextView
                    android:id="@+id/playback_vod_favorite_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_playback_favorite_button"
                    android:drawablePadding="10dp"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:paddingStart="18dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="10dp"
                    android:text="@string/playback_add_to_favorites"
                    android:textAllCaps="false"
                    android:textColor="@color/sidebar_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_sidebar_favorite" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Live TV: horizontal EPG strip shown on DPAD up/down. Past left, current centre, future right. -->
    <FrameLayout
        android:id="@+id/playback_live_info_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="false"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:clipChildren="false"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="100dp">

            <!-- Channel name + wall-clock time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/playback_live_channel_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Live - Sport 5" />

                <TextView
                    android:id="@+id/playback_live_current_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    tools:text="19:50" />
            </LinearLayout>

            <!-- Horizontal EPG card strip. Cards overflow parent via clipChildren=false. -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/playback_live_epg_rv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:descendantFocusability="blocksDescendants"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:overScrollMode="never" />

        </LinearLayout>
    </FrameLayout>

</FrameLayout>
