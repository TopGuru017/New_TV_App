<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_reminder_item"
    android:focusable="true"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/reminder_channel_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        tools:src="@mipmap/ic_launcher" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_tv_guide_bell" />

            <TextView
                android:id="@+id/reminder_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="12sp"
                tools:text="01:50 - 03:10" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text=" | "
                android:textColor="@color/sidebar_text_muted"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/reminder_channel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/sidebar_text_primary"
                android:textSize="12sp"
                tools:text="Channel 12" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text=" | "
                android:textColor="@color/sidebar_text_muted"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/reminder_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/sidebar_text_primary"
                android:textSize="12sp"
                tools:text="The Race to a Million - All the cards are shuffled" />
        </LinearLayout>

        <TextView
            android:id="@+id/reminder_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/sidebar_text_muted"
            android:textSize="11sp"
            tools:text="Or and Adi do not stop, and as long as they put their feet..." />
    </LinearLayout>

    <ImageView
        android:id="@+id/reminder_delete_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="12dp"
        android:contentDescription="@string/reminders_delete_yes"
        android:src="@drawable/ic_reminder_delete" />
</LinearLayout>
