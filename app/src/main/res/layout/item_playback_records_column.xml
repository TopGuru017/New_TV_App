<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_playback_trick_card"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:focusable="true"
    android:foreground="@drawable/fg_playback_trick_focus">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <ImageView
            android:id="@+id/playback_records_col_thumb"
            android:layout_width="80dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_playback_record_thumb"
            android:contentDescription="@null"
            android:focusable="false"
            android:padding="4dp"
            android:scaleType="centerCrop"
            tools:background="#333" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/playback_records_col_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="11sp"
                tools:text="23:50 - 00:45" />

            <TextView
                android:id="@+id/playback_records_col_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:focusable="false"
                android:maxLines="2"
                android:textColor="@color/sidebar_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Title" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
