<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/last_watch_vod_big_width"
    android:layout_height="@dimen/last_watch_vod_big_height"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_last_watch_vod_card_normal"
    android:clickable="true"
    android:clipChildren="true"
    android:descendantFocusability="blocksDescendants"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:foreground="@drawable/fg_last_watch_vod_card">

    <ImageView
        android:id="@+id/last_watch_vod_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:focusable="false"
        android:clickable="false"
        tools:background="#333" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_last_watch_vod_scrim"
        android:layout_margin="2dp"
        android:focusable="false"
        android:clickable="false" />

    <TextView
        android:id="@+id/last_watch_vod_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp"
        android:textColor="@color/sidebar_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:focusable="false"
        android:clickable="false"
        android:maxLines="2"
        android:ellipsize="end"
        tools:text="What's the problem? Season 4" />

    <TextView
        android:id="@+id/last_watch_vod_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="46dp"
        android:textColor="@color/sidebar_text_muted"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:focusable="false"
        android:clickable="false"
        tools:text="Episode 7" />
</FrameLayout>

