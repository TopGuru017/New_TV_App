<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/playback_live_card_width"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    android:background="@drawable/bg_playback_records_info_card"
    android:orientation="vertical">

    <!-- ▲ above card (visible only on selected) -->
    <TextView
        android:id="@+id/live_card_arrow_up"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:gravity="center"
        android:importantForAccessibility="no"
        android:text="▲"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:visibility="invisible" />

    <!-- Main row: ◄  [thumbnail]  [info column]  ► -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/live_card_arrow_left"
            android:layout_width="@dimen/playback_live_arrow_gutter"
            android:layout_height="match_parent"
            android:gravity="center"
            android:importantForAccessibility="no"
            android:text="◄"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:visibility="invisible" />

        <ImageView
            android:id="@+id/live_card_thumb"
            android:layout_width="@dimen/playback_live_epg_thumb_width"
            android:layout_height="@dimen/playback_live_epg_thumb_height"
            android:contentDescription="@null"
            android:padding="2dp"
            android:scaleType="centerCrop"
            tools:background="#223344" />

        <!-- Info column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <!-- Time range + badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/live_card_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    tools:text="02:00 - 04:40" />

                <TextView
                    android:id="@+id/live_card_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:paddingStart="5dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="5dp"
                    android:paddingBottom="2dp"
                    android:textColor="@android:color/white"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:background="@drawable/bg_playback_live_badge_live"
                    tools:text="LIVE"
                    tools:visibility="visible" />
            </LinearLayout>

            <!-- Programme title -->
            <TextView
                android:id="@+id/live_card_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Direct! Miami - Philadelphia" />

            <!-- Description -->
            <TextView
                android:id="@+id/live_card_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                tools:text="Live Broadcast: Basketball. League 5-NBA: Miami Heat host Philadelphia 76ers." />

            <!-- Genre -->
            <TextView
                android:id="@+id/live_card_genre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#99FFFFFF"
                android:textSize="10sp"
                tools:text="Sports" />

        </LinearLayout>

        <TextView
            android:id="@+id/live_card_arrow_right"
            android:layout_width="@dimen/playback_live_arrow_gutter"
            android:layout_height="match_parent"
            android:gravity="center"
            android:importantForAccessibility="no"
            android:text="►"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:visibility="invisible" />
    </LinearLayout>

    <!-- ▼ below card (visible only on selected) -->
    <TextView
        android:id="@+id/live_card_arrow_down"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:gravity="center"
        android:importantForAccessibility="no"
        android:text="▼"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:visibility="invisible" />

</LinearLayout>
