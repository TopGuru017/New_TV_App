<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:src="@drawable/sdarot_bg" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/login_scrim" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="48dp"
        android:paddingTop="36dp"
        android:paddingEnd="48dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/login_lang_he"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_login_flag_ring"
                android:contentDescription="@string/login_lang_hebrew"
                android:focusable="true"
                android:nextFocusDown="@id/login_lang_en"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_flag_il" />

            <ImageButton
                android:id="@+id/login_lang_en"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_login_flag_ring"
                android:contentDescription="@string/login_lang_english"
                android:focusable="true"
                android:nextFocusDown="@id/login_username"
                android:nextFocusUp="@id/login_lang_he"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_flag_gb" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:maxWidth="460dp"
            android:minWidth="360dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/login_hello"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_hello"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_brand_israel"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/login_brand_tv"
                    android:textColor="@color/sidebar_accent_cyan"
                    android:textSize="34sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/login_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/login_subtitle"
                android:textColor="#CCFFFFFF"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/login_username"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_login_field"
                android:drawableStart="@drawable/ic_profile_email"
                android:drawablePadding="12dp"
                android:drawableTint="#FFFFFF"
                android:hint="@string/login_username_hint"
                android:imeOptions="actionNext"
                android:importantForAutofill="no"
                android:inputType="text|textNoSuggestions"
                android:maxLines="1"
                android:nextFocusDown="@id/login_password"
                android:nextFocusUp="@id/login_lang_en"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#88FFFFFF"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/login_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_login_field"
                android:drawableStart="@drawable/ic_profile_shield"
                android:drawablePadding="12dp"
                android:drawableTint="#FFFFFF"
                android:hint="@string/login_password_hint"
                android:imeOptions="actionDone"
                android:importantForAutofill="no"
                android:inputType="textPassword|textNoSuggestions"
                android:maxLines="1"
                android:nextFocusDown="@id/login_submit"
                android:nextFocusUp="@id/login_username"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#88FFFFFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/login_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="#FF8A80"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="Error"
                tools:visibility="visible" />

            <Button
                android:id="@+id/login_submit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_login_button"
                android:focusable="true"
                android:nextFocusDown="@id/login_qr"
                android:nextFocusUp="@id/login_password"
                android:text="@string/login_button"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <Button
                android:id="@+id/login_qr"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_login_button"
                android:focusable="true"
                android:nextFocusDown="@id/login_reset"
                android:nextFocusUp="@id/login_submit"
                android:text="@string/login_qr"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <ProgressBar
                android:id="@+id/login_progress"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/sidebar_accent_cyan"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="8dp"
            android:gravity="end"
            android:orientation="vertical">

            <Button
                android:id="@+id/login_reset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_login_button"
                android:focusable="true"
                android:minHeight="44dp"
                android:nextFocusUp="@id/login_qr"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/login_reset_password"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/login_build"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                tools:text="Build: …" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
