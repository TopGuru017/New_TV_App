<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/content_background">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/home_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/last_watch_padding_start"
            android:paddingTop="@dimen/last_watch_padding_top"
            android:paddingEnd="@dimen/last_watch_padding_end"
            android:paddingBottom="@dimen/last_watch_padding_bottom">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/home_last_watch_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/last_watch_title"
                    android:textColor="@color/sidebar_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="last watch" />

                <TextView
                    android:id="@+id/home_last_watch_edit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_search_clear_button"
                    android:paddingStart="18dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="10dp"
                    android:text="@string/last_watch_edit"
                    android:textColor="@color/sidebar_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:textAllCaps="false"
                    tools:text="Edit" />
            </LinearLayout>

            <TextView
                android:id="@+id/home_last_watch_header_records"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/last_watch_section_header_margin_top"
                android:text="@string/last_watch_header_records"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="14sp"
                tools:text="RECORDS" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/home_last_watch_records_rv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/home_last_watch_header_series"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/last_watch_section_header_margin_top"
                android:text="@string/last_watch_header_vod_series"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="14sp"
                tools:text="VOD - SERIES" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/home_last_watch_series_rv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/home_last_watch_header_movies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/last_watch_section_header_margin_top"
                android:text="@string/last_watch_header_vod_movies"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="14sp"
                tools:text="VOD - MOVIES" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/home_last_watch_movies_rv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/home_last_watch_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:text="@string/last_watch_empty"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="15sp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
