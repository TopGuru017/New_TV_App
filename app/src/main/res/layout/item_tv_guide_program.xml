<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/tv_guide_program_spacing"
    android:background="@drawable/bg_tv_guide_program"
    android:focusable="true"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="68dp"
        android:background="#1A1A1A">

        <ImageView
            android:id="@+id/tv_guide_program_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />

        <ProgressBar
            android:id="@+id/tv_guide_progress"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_gravity="bottom"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/bg_tv_guide_now_progress"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/tv_guide_program_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_tv_guide_clock" />

            <TextView
                android:id="@+id/tv_guide_program_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="12sp"
                tools:text="01:00 - 01:50" />

            <TextView
                android:id="@+id/tv_guide_now_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tv_guide_now_badge"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:text="@string/tv_guide_now"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_guide_program_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/sidebar_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Studio 6 - The Stories" />

        <TextView
            android:id="@+id/tv_guide_program_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"
            android:maxLines="3"
            android:textColor="@color/sidebar_text_muted"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="Description text"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/tv_guide_program_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:orientation="horizontal"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tv_guide_program_genre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="11sp"
                tools:text="Genre: News &amp; Current Affairs" />

            <TextView
                android:id="@+id/tv_guide_program_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="11sp"
                tools:text="Time: 00:50:00" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
