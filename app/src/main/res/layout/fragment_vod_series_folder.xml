<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-screen blurred backdrop -->
    <ImageView
        android:id="@+id/series_hero_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <!-- Darker overlay for readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

    <!-- Main content -->
    <LinearLayout
        android:id="@+id/series_main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="18dp"
        android:paddingEnd="28dp"
        android:paddingBottom="12dp">

        <!-- HERO ROW: thumbnail on left, info on right, action buttons top-right -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <!-- Series thumbnail (portrait ratio) -->
                <ImageView
                    android:id="@+id/series_hero_thumbnail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="24"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop" />

                <!-- Info column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="76"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="76dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/series_hero_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E53935"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="SERIES" />

                    <TextView
                        android:id="@+id/series_hero_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="The Amazing Race" />

                    <TextView
                        android:id="@+id/series_hero_genre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/sidebar_text_muted"
                        android:textSize="13sp"
                        tools:text="Reality TV | 2026" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:background="#38FFFFFF" />

                    <TextView
                        android:id="@+id/series_hero_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:ellipsize="end"
                        android:lineSpacingExtra="3dp"
                        android:maxLines="4"
                        android:textColor="@color/sidebar_text_primary"
                        android:textSize="14sp"
                        tools:text="Description of the series..." />

                    <TextView
                        android:id="@+id/series_hero_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/sidebar_text_muted"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:text="(75 minutes)" />
                </LinearLayout>
            </LinearLayout>

            <!-- Top-right action buttons (heart + sort) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/series_btn_favorite"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_series_action_icon_btn"
                    android:clickable="true"
                    android:contentDescription="@string/playback_add_to_favorites"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_sidebar_favorite" />

                <ImageView
                    android:id="@+id/series_btn_sort"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_series_action_icon_btn"
                    android:clickable="true"
                    android:contentDescription="@string/vod_series_sort"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_series_sort" />
            </LinearLayout>
        </FrameLayout>

        <!-- Controls row: season dropdown + order toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/series_season_btn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_series_dropdown_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minWidth="150dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/sidebar_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Season 10  ▼" />

        </LinearLayout>

        <!-- Episodes grid -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="5">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/series_episodes_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/series_episodes_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/vod_empty_items"
                android:textColor="@color/sidebar_text_muted"
                android:textSize="14sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- Season dropdown overlay (shown when season button is pressed) -->
    <LinearLayout
        android:id="@+id/series_season_dropdown"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginStart="28dp"
        android:background="@drawable/bg_series_dropdown_overlay"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/series_season_dropdown_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/series_loading"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/series_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="24dp"
        android:textColor="#EF5350"
        android:textSize="15sp"
        android:visibility="gone"
        tools:text="@string/vod_series_episode_error" />

</FrameLayout>
