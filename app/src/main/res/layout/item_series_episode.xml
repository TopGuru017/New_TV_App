<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_series_episode_tile"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/episode_thumbnail"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:background="#333" />

        <ProgressBar
            android:id="@+id/episode_watch_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_marginBottom="6dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="#55000000"
            android:progressTint="@color/sidebar_accent_cyan"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/episode_thumbnail"
            app:layout_constraintEnd_toEndOf="@id/episode_thumbnail"
            app:layout_constraintStart_toStartOf="@id/episode_thumbnail"
            />

        <TextView
            android:id="@+id/episode_watch_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_series_episode_watched_badge"
            android:paddingStart="8dp"
            android:paddingTop="2dp"
            android:paddingEnd="8dp"
            android:paddingBottom="2dp"
            android:textColor="@color/sidebar_text_primary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/episode_thumbnail"
            app:layout_constraintTop_toTopOf="@id/episode_thumbnail"
            tools:text="WATCHED" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/episode_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/sidebar_accent_cyan"
        android:textSize="10sp"
        android:textStyle="bold"
        tools:text="Episode 22" />

    <TextView
        android:id="@+id/episode_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:layout_marginBottom="3dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/sidebar_text_primary"
        android:textSize="11sp"
        tools:text="The painful impeachment" />

</LinearLayout>
