<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ProfileCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_profile_card</item>
        <item name="android:focusable">true</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="ProfileLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/profile_label_cyan</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="ProfileValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/sidebar_text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>
